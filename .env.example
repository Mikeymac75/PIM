# Flask Secret Key (Required for session management)
# Generate a strong key, e.g., by running: python -c "import os; print(os.urandom(24).hex())"
FLASK_SECRET_KEY='your_strong_random_secret_key_here'

# Database File Path (Optional)
# If commented out or not set, defaults to 'instance/food_app.db'
# DATABASE_FILE_PATH='instance/food_app.db'
# Example for a custom path:
# DATABASE_FILE_PATH='/opt/data/my_food_inventory.db'

# Enable Admin Routes (Optional)
# Set to 'true' to enable backup/restore functionality.
# Any other value (or if not set) will keep admin routes disabled.
# FLASK_ENABLE_ADMIN_ROUTES='false'
# Example to enable:
# FLASK_ENABLE_ADMIN_ROUTES='true'
